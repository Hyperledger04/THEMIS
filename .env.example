# ============================================================
# LexAgent — Environment Variables
# Copy this file to .env and fill in your keys.
# ============================================================

# ------------------------------------------------------------
# LLM — Bring Your Own Key (BYOK)
# Set the provider and model you want to use.
# Only one provider needs a key to run LexAgent.
# ------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...        # Claude (default)
OPENAI_API_KEY=sk-...               # GPT-4o, GPT-4-turbo, etc.
GOOGLE_API_KEY=...                  # Gemini Pro / Ultra
OPENROUTER_API_KEY=...              # 100+ models via openrouter.ai
# GROQ_API_KEY=...                  # Groq (ultra-fast inference)
# MISTRAL_API_KEY=...               # Mistral AI

# Which model to use (provider/model format for LiteLLM)
LEX_MODEL=claude-sonnet-4-6
LEX_MODEL_PROVIDER=anthropic
# LEX_MODEL_BASE_URL=               # For local models (e.g. http://localhost:11434 for Ollama)

# ------------------------------------------------------------
# Legal Data Sources — Bring Your Own Key / MCP (BYO-MCP)
# ------------------------------------------------------------

# Indian Kanoon backend: stub | api | mcp
# stub = mock data (default, works offline)
# api  = direct API with your key
# mcp  = use a configured MCP server
LEX_KANOON_BACKEND=stub
KANOON_API_KEY=

# eCourts backend: stub | api | mcp
LEX_ECOURTS_BACKEND=stub

# CourtListener (US courts)
COURTLISTENER_API_KEY=

# MCP server name for legal data (when using mcp backend)
LEX_KANOON_MCP=E-courts

# ------------------------------------------------------------
# Messaging Gateways (Phase 7)
# ------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# ------------------------------------------------------------
# LexAgent Paths (optional — defaults work out of the box)
# ------------------------------------------------------------

# LEX_HOME=~/.lexagent
# LEX_SKILLS_DIR=~/.lexagent/skills
# LEX_MATTERS_DIR=~/.lexagent/matters
# LEX_SESSIONS_DB=~/.lexagent/sessions.db

# ------------------------------------------------------------
# Phase 9B: Voice AI Gateway
# Run `lex voice` to start. Browser client: http://localhost:8001/voice/client
# Install extras first: uv sync --extra voice
# ------------------------------------------------------------

# Enable the voice gateway (opt-in — existing Telegram/CLI unaffected)
# LEX_VOICE_ENABLED=true

# STT (Speech-to-Text): stub | whisper | deepgram
# stub   = no API key, returns fixed text (for local dev/tests)
# whisper = OpenAI Whisper API (reuses OPENAI_API_KEY above)
# deepgram = Deepgram Nova-2 (best Indian English accuracy)
LEX_STT_BACKEND=stub
# LEX_STT_LANGUAGE=en-IN
DEEPGRAM_API_KEY=

# TTS (Text-to-Speech): stub | google | elevenlabs
# stub      = silent (no audio playback)
# google    = Google Cloud TTS en-IN-Wavenet-D voice (needs GOOGLE_TTS_API_KEY or ADC)
# elevenlabs = ElevenLabs Turbo v2 (highest quality, needs ELEVENLABS_API_KEY)
LEX_TTS_BACKEND=stub
GOOGLE_TTS_API_KEY=
# LEX_GOOGLE_TTS_VOICE=en-IN-Wavenet-D
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Default: ElevenLabs Rachel

# Twilio phone gateway (optional — browser WebSocket works without Twilio)
# Sign up at https://www.twilio.com/try-twilio (free trial)
# Then: lex voice --twilio  to see webhook setup instructions
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
